          "label": "Top"
        },
        {
          "value": "bottom",
          "label": "Bottom"
        }
      ],
      "default": "center"
    },
    {
      "type": "header",
      "content": "Customer information"
    },
    {
      "type": "text",
      "id": "customer_name",
      "label": "Name",
      "default": "Camille D."
    },
    {
      "type": "text",
      "id": "customer_age",
      "label": "Age",
      "default": "32 ans"
    },
    {
      "type": "text",
      "id": "customer_city",
      "label": "City",
      "default": "Lyon"
    },
    {
